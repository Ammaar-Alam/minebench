generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum CustomBuildStatus {
  queued
  running
  succeeded
  failed
  canceled
}

enum CustomBuildJobType {
  generate
  export
}

enum CustomBuildJobStatus {
  queued
  running
  succeeded
  failed
  canceled
}

enum CustomBuildArtifactKind {
  build_json
  preview_json
  raw_text_debug
  glb
  stl
  schem
}

enum CustomBuildStorageEncoding {
  identity
  gzip
}

model Model {
  id          String   @id @default(cuid())
  key         String   @unique
  provider    String
  modelId     String
  displayName String
  enabled     Boolean  @default(true)
  isBaseline  Boolean  @default(false)

  eloRating     Float @default(1500)
  glickoRd      Float @default(350)
  glickoVolatility Float @default(0.06)
  conservativeRating Float @default(800)
  shownCount    Int   @default(0)
  winCount      Int   @default(0)
  lossCount     Int   @default(0)
  drawCount     Int   @default(0)
  bothBadCount  Int   @default(0)

  builds Build[]
  matchupsAsA Matchup[] @relation("MatchupModelA")
  matchupsAsB Matchup[] @relation("MatchupModelB")
  rankSnapshots ModelRankSnapshot[]
  coverageByPrompt ArenaCoverageModelPrompt[]
  coveragePairsLow ArenaCoveragePair[] @relation("ArenaCoveragePairLow")
  coveragePairsHigh ArenaCoveragePair[] @relation("ArenaCoveragePairHigh")
  coveragePairPromptsLow ArenaCoveragePairPrompt[] @relation("ArenaCoveragePairPromptLow")
  coveragePairPromptsHigh ArenaCoveragePairPrompt[] @relation("ArenaCoveragePairPromptHigh")
  shownJobs ArenaShownJob[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled])
  @@index([conservativeRating])
}

model ModelRankSnapshot {
  id         String   @id @default(cuid())
  capturedAt DateTime
  rank       Int
  rankScore  Float
  confidence Int

  modelId String
  model   Model @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([capturedAt, modelId])
  @@index([capturedAt])
  @@index([capturedAt, rank])
  @@index([modelId])
}

model Prompt {
  id        String   @id @default(cuid())
  text      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  builds  Build[]
  matchups Matchup[]
  coverageByModel ArenaCoverageModelPrompt[]
  coveragePairs ArenaCoveragePairPrompt[]

  @@unique([text])
  @@index([active])
}

model Build {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  promptId String
  prompt   Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  modelId String
  model   Model @relation(fields: [modelId], references: [id], onDelete: Cascade)

  gridSize Int
  palette  String
  mode     String

  voxelData         Json?
  voxelStorageBucket String?
  voxelStoragePath   String?
  voxelStorageEncoding String?
  voxelByteSize      Int?
  voxelCompressedByteSize Int?
  voxelSha256        String?
  arenaBuildHints    Json?
  arenaSnapshotPreview Json?
  arenaSnapshotPreviewChecksum String?
  arenaSnapshotFull  Json?
  arenaSnapshotFullChecksum String?
  blockCount        Int
  generationTimeMs  Int

  matchupsAsA Matchup[] @relation("MatchupBuildA")
  matchupsAsB Matchup[] @relation("MatchupBuildB")

  @@unique([promptId, modelId, gridSize, palette, mode])
  @@index([gridSize, palette, mode, promptId, modelId])
  @@index([promptId])
  @@index([modelId])
}

model Matchup {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  samplingLane String?
  samplingReason String?

  promptId String
  prompt   Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  modelAId String
  modelA   Model @relation("MatchupModelA", fields: [modelAId], references: [id], onDelete: Restrict)

  modelBId String
  modelB   Model @relation("MatchupModelB", fields: [modelBId], references: [id], onDelete: Restrict)

  buildAId String
  buildA   Build @relation("MatchupBuildA", fields: [buildAId], references: [id], onDelete: Restrict)

  buildBId String
  buildB   Build @relation("MatchupBuildB", fields: [buildBId], references: [id], onDelete: Restrict)

  votes Vote[]

  @@index([promptId, createdAt])
  @@index([modelAId])
  @@index([modelBId])
  @@index([samplingLane, createdAt])
}

model Vote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  matchupId String
  matchup   Matchup @relation(fields: [matchupId], references: [id], onDelete: Cascade)
  jobs      ArenaVoteJob[]

  sessionId String
  choice    String

  @@unique([matchupId, sessionId])
  @@index([sessionId])
  @@index([createdAt])
  @@index([matchupId, createdAt])
}

model ArenaVoteJob {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  voteId  String @unique
  vote    Vote   @relation(fields: [voteId], references: [id], onDelete: Cascade)

  matchupId String
  promptId  String
  modelAId  String
  modelBId  String
  choice    String

  @@index([matchupId])
}

model ArenaShownJob {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  modelId String
  model   Model @relation(fields: [modelId], references: [id], onDelete: Cascade)

  count Int @default(1)

  @@index([modelId])
}

model ArenaCoverageModelPrompt {
  modelId String
  promptId String
  decisiveVotes Int @default(0)

  model Model @relation(fields: [modelId], references: [id], onDelete: Cascade)
  prompt Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@id([modelId, promptId])
  @@index([promptId])
}

model ArenaCoveragePair {
  modelLowId String
  modelHighId String
  decisiveVotes Int @default(0)

  modelLow Model @relation("ArenaCoveragePairLow", fields: [modelLowId], references: [id], onDelete: Cascade)
  modelHigh Model @relation("ArenaCoveragePairHigh", fields: [modelHighId], references: [id], onDelete: Cascade)

  @@id([modelLowId, modelHighId])
}

model ArenaCoveragePairPrompt {
  modelLowId String
  modelHighId String
  promptId String
  decisiveVotes Int @default(0)

  modelLow Model @relation("ArenaCoveragePairPromptLow", fields: [modelLowId], references: [id], onDelete: Cascade)
  modelHigh Model @relation("ArenaCoveragePairPromptHigh", fields: [modelHighId], references: [id], onDelete: Cascade)
  prompt Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@id([modelLowId, modelHighId, promptId])
  @@index([promptId])
}

model CustomBuild {
  id          String   @id @default(cuid())
  publicId    String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  startedAt   DateTime?
  completedAt DateTime?

  status       CustomBuildStatus @default(queued)
  currentStage String?
  progress     Json?

  promptText     String
  promptSha256   String
  gridSize       Int
  palette        String
  mode           String @default("precise")
  generationMode String @default("tool")

  modelKind         String
  modelKey          String?
  modelProvider     String
  modelId           String
  modelDisplayName  String
  openRouterModelId String?
  customBaseUrl     String?
  preferOpenRouter  Boolean @default(false)
  reasoning         String?

  blockCount       Int?
  generationTimeMs Int?
  warnings         Json?
  metrics          Json?

  buildSha256             String?
  buildByteSize           Int?
  buildCompressedByteSize Int?
  previewBlockCount       Int?
  previewSha256           String?

  errorCode      String?
  errorMessage   String?
  errorRetryable Boolean?

  requestedIpHash        String?
  requestedUserAgentHash String?

  jobs      CustomBuildJob[]
  artifacts CustomBuildArtifact[]
  events    CustomBuildEvent[]
  secret    CustomBuildSecret?

  @@index([status, createdAt])
  @@index([createdAt])
  @@index([promptSha256])
  @@index([modelProvider, modelId])
}

model CustomBuildSecret {
  id            String @id @default(cuid())
  customBuildId String @unique
  customBuild   CustomBuild @relation(fields: [customBuildId], references: [id], onDelete: Cascade)

  provider      String
  keyCiphertext String
  keyIv         String
  keyAuthTag    String?
  keyVersion    Int @default(1)
  expiresAt     DateTime
  consumedAt    DateTime?
  deletedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}

model CustomBuildJob {
  id            String @id @default(cuid())
  customBuildId String
  customBuild   CustomBuild @relation(fields: [customBuildId], references: [id], onDelete: Cascade)

  type     CustomBuildJobType
  status   CustomBuildJobStatus @default(queued)
  payload  Json?
  priority Int @default(0)

  attempts    Int @default(0)
  maxAttempts Int @default(3)
  runAfter    DateTime @default(now())

  lockedBy       String?
  lockedAt       DateTime?
  leaseExpiresAt DateTime?

  startedAt        DateTime?
  completedAt      DateTime?
  lastErrorCode    String?
  lastErrorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, runAfter, priority, createdAt])
  @@index([leaseExpiresAt])
  @@index([customBuildId, type, status])
}

model CustomBuildArtifact {
  id            String @id @default(cuid())
  customBuildId String
  customBuild   CustomBuild @relation(fields: [customBuildId], references: [id], onDelete: Cascade)

  kind        CustomBuildArtifactKind
  format      String
  bucket      String
  path        String
  encoding    CustomBuildStorageEncoding @default(identity)
  contentType String
  fileName    String

  sha256             String
  sourceBuildSha256  String?
  byteSize           Int
  compressedByteSize Int?
  blockCount         Int?
  exportStats        Json?

  createdAt DateTime @default(now())

  @@unique([customBuildId, kind, sourceBuildSha256])
  @@index([customBuildId, kind])
  @@index([sha256])
}

model CustomBuildEvent {
  id            String @id @default(cuid())
  customBuildId String
  customBuild   CustomBuild @relation(fields: [customBuildId], references: [id], onDelete: Cascade)

  seq       Int
  type      String
  data      Json?
  createdAt DateTime @default(now())

  @@unique([customBuildId, seq])
  @@index([customBuildId, createdAt])
}

model CustomBuildStatsDaily {
  day              DateTime @id
  created          Int @default(0)
  succeeded        Int @default(0)
  failed           Int @default(0)
  canceled         Int @default(0)
  exportsRequested Int @default(0)
  exportsSucceeded Int @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
