{
  "name": "minebench",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "env:ensure": "node scripts/ensure-env.mjs",
    "env:localdb": "node scripts/prepare-local-env.mjs",
    "prelocal:dev": "pnpm env:localdb",
    "prelocal:db:refresh": "pnpm env:localdb",
    "prelocal:prisma:migrate": "pnpm env:localdb",
    "prelocal:prompt": "pnpm env:localdb",
    "db:wait": "node scripts/wait-for-db.mjs",
    "dev:setup": "pnpm env:ensure && pnpm atlas && pnpm db:reset && pnpm db:wait && pnpm prisma:migrate && pnpm dev",
    "dev": "next dev",
    "local:dev": "node scripts/with-local-env.mjs next dev",
    "local:db:refresh": "node scripts/refresh-local-db-from-remote.mjs",
    "local:prisma:migrate": "node scripts/with-local-env.mjs prisma migrate deploy",
    "local:prompt": "node scripts/with-local-env.mjs tsx scripts/prompt.ts",
    "prebuild": "prisma generate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "pretest": "prisma generate",
    "test": "tsx tests/run.ts",
    "test:unit": "tsx tests/run.ts tests/unit",
    "test:config": "tsx tests/run.ts tests/config",
    "test:ui": "tsx tests/run.ts tests/ui",
    "test:integration": "tsx tests/run.ts tests/integration",
    "check": "pnpm lint && pnpm test && pnpm build",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:dev": "prisma migrate dev",
    "atlas": "node scripts/build-texture-atlas.mjs",
    "atlas:audit": "node scripts/audit-texture-pack.mjs",
    "batch:generate": "tsx scripts/batch-generate.ts",
    "batch:status": "tsx scripts/batch-generate.ts",
    "tool:convert": "tsx scripts/convert-voxel-tool-call.ts",
    "uploads:sync": "tsx scripts/sync-uploads-from-db.ts",
    "prompt": "tsx scripts/prompt.ts",
    "elo:reset": "tsx scripts/reset-elo.ts",
    "elo:recompute": "tsx scripts/recompute-elo.ts",
    "arena:load": "tsx scripts/load-arena.ts",
    "arena:metadata:backfill": "tsx scripts/backfill-arena-build-metadata.ts",
    "arena:snapshot:precompute": "tsx scripts/precompute-arena-snapshot-artifacts.ts",
    "arena:stream:precompute": "tsx scripts/precompute-arena-stream-artifacts.ts",
    "arena:stream:clear": "tsx scripts/clear-arena-stream-artifacts.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@vercel/analytics": "^1.6.1",
    "fflate": "^0.8.2",
    "gifenc": "^1.0.3",
    "gifsicle-wasm-browser": "^1.5.19",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.172.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.182.0",
    "dotenv": "^16.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "prisma": "^6.0.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
